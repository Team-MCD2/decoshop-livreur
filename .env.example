# =====================================================================
# DecoShop Livreur — Environnement de développement
# Copier ce fichier en `.env.local` puis remplir avec tes vraies valeurs.
# Ne JAMAIS commiter `.env.local` (déjà dans .gitignore).
# =====================================================================

# --------- Supabase ---------
# Trouvable dans Supabase Studio → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --------- Mapbox (Phase 3) ---------
# Trouvable dans Mapbox account → Tokens
# VITE_MAPBOX_TOKEN=pk.eyJ1IjoieW91ci11c2VybmFtZSIsImEiOi...

# --------- Resend (Phase 2) ---------
# Pour l'envoi d'emails transactionnels (côté Edge Function uniquement,
# clé NON exposée au client). Configuré dans Supabase secrets.
# RESEND_API_KEY=re_...

# --------- VAPID Web Push (Phase 7) ---------
# Génération : npx web-push generate-vapid-keys
# Public key seule exposée au client. Clé privée côté Edge Function.
# VITE_VAPID_PUBLIC_KEY=BHK...

# --------- App config ---------
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=DecoShop Livreur
VITE_DEFAULT_LANGUAGE=fr
