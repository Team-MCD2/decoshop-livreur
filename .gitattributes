# Auto-detect text files and normalise line endings to LF on commit.
# Prevents Windows CRLF noise in diffs across the team.
* text=auto eol=lf

# Windows-only scripts keep CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf

# Binary assets explicitly marked binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
